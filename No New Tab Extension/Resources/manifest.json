{
    "manifest_version": 3,
    "name": "No New Tab",
    "version": "1.1",
    "permissions": ["tabs", "storage"],
    "background": {
        "scripts": ["background.js"],
        "type": "module"
    },
    "content_scripts": [{
        "js": ["content.js"],
        "matches": ["<all_urls>"]
    }],
    "icons": {
        "128": "images/drake.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "images/drake.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["images/drake.png"],
            "matches": ["<all_urls>"]
        }
    ]
}
